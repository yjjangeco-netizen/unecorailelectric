{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/nara-monitoring/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/assistant/daily-summary",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/assistant/morning-brief",
      "schedule": "1 23 * * 0-4"
    },
    {
      "path": "/api/assistant/work-report-reminder",
      "schedule": "30 7 * * 1-5"
    },
    {
      "path": "/api/nara-monitoring/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
