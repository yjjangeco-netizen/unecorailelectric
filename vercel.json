{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/nara-monitoring/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/nara-monitoring/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
