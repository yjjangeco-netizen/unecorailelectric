<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_memo_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:includeFontPadding="false" android:text="메모" android:textColor="#FF111827" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_memo_add_btn" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:text="＋" android:textColor="#FF2563EB" android:textSize="18sp" android:textStyle="bold" />
    </LinearLayout>

    <TextView android:id="@+id/widget_memo_empty" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:gravity="center" android:text="앱에서 메모를 한 번 열면 표시됩니다" android:textColor="#FF9CA3AF" android:textSize="12sp" android:visibility="gone" />

    <LinearLayout android:id="@+id/memo_0_root" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
      <View android:id="@+id/memo_0_bar" android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="#FFFACC15" />
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/memo_0_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:includeFontPadding="false" android:maxLines="1" android:text="" android:textColor="#FF111827" android:textSize="13sp" android:textStyle="bold" />
        <TextView android:id="@+id/memo_0_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:ellipsize="end" android:includeFontPadding="false" android:maxLines="2" android:text="" android:textColor="#FF4B5563" android:textSize="11sp" />
      </LinearLayout>
    </LinearLayout>
    <LinearLayout android:id="@+id/memo_1_root" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
